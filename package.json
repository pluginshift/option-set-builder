{
  "name": "option-set-builder",
  "version": "1.0.0",
  "private": true,
  "description": "Option Set Builder — admin builder and storefront runtime.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "wp-scripts start",
    "dev": "wp-scripts start",
    "watch": "wp-scripts start",
    "build": "wp-scripts build",
    "lint:js": "wp-scripts lint-js",
    "lint:css": "wp-scripts lint-style",
    "pot": "wp i18n make-pot . languages/option-set-builder.pot --slug=option-set-builder --domain=option-set-builder --include=includes,assets/src --exclude=node_modules,vendor,assets/build,tests,dist,build,.git,.github,.claude",
    "prezip": "npm run build && npm run pot",
    "zip": "rm -f option-set-builder.zip && wp dist-archive . ./option-set-builder.zip --plugin-dirname=option-set-builder",
    "release": "npm run zip"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "classnames": "^2.5.1",
    "cmdk": "^1.1.1",
    "flatpickr": "^4.6.13",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.460.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@wordpress/scripts": "^27.9.0",
    "sass": "^1.77.0"
  }
}
